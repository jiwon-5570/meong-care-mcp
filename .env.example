# Express 서버가 사용할 포트입니다.
# 값을 비우면 코드에서 기본값 3000을 사용합니다.
PORT=3000

# 공공데이터포털 API 인증키입니다.
# 동물병원 API 등 공공데이터 API 호출에 공통으로 사용합니다.
# 현재 MVP는 이 값이 비어 있어도 로컬 샘플 데이터로 동작합니다.
PUBLIC_DATA_SERVICE_KEY=

# 동물병원 인허가/조회 공공데이터 API URL입니다.
# 예: 공공데이터포털에서 발급받은 동물병원 관련 API endpoint
PUBLIC_DATA_ANIMAL_HOSPITAL_API_URL=https://apis.data.go.kr/1741000/animal_hospitals/info

# 동물병원 검색 시 공공데이터 API를 사용할지 여부입니다.
# false: src/data/animalHospitals.sample.json 샘플 데이터 사용
# true: PUBLIC_DATA_ANIMAL_HOSPITAL_API_URL 호출, 실패 시 샘플 데이터 fallback
USE_PUBLIC_DATA_API=false

# 증상 분류/표준 증상 사전 공공데이터 API URL입니다.
# 현재 확인 가능한 공식 공공데이터 OpenAPI가 없어 비워두고 로컬 사전 fallback을 사용합니다.
PUBLIC_DATA_SYMPTOM_API_URL=

# 증상 분류 시 공공데이터 API를 사용할지 여부입니다.
# false: src/data/symptomDictionary.sample.json 로컬 증상 사전 사용
# true: PUBLIC_DATA_SYMPTOM_API_URL 호출, 실패 시 로컬 증상 사전 fallback
USE_SYMPTOM_PUBLIC_DATA=false

# 사진 관찰 기록을 저장할 JSON 파일 경로입니다.
# 비워두면 로컬 실행에서는 src/data/photoRecords.json을 사용합니다.
# Docker/KakaoCloud에서는 Dockerfile 기본값인 /app/data/photoRecords.json을 사용합니다.
PHOTO_RECORDS_PATH=

# 위험 음식 섭취 기록을 저장할 JSON 파일 경로입니다.
# 비워두면 로컬 실행에서는 src/data/foodIngestionRecords.json을 사용합니다.
# Docker/KakaoCloud에서는 Dockerfile 기본값인 /app/data/foodIngestionRecords.json을 사용합니다.
FOOD_INGESTION_RECORDS_PATH=

# Anthropic Claude 이미지 분석 API 키입니다.
# 비워두면 사진 AI 분석은 건너뛰고 기존 룰 기반 기록 보조만 사용합니다.
ANTHROPIC_API_KEY=

# Anthropic 모델명입니다. 필요하면 Anthropic 콘솔/문서의 실제 API model id로 교체하세요.
ANTHROPIC_MODEL=claude-sonnet-4-6
