# Express 서버 포트입니다.
PORT=3000

# 공공데이터포털 API 인증키입니다.
# 실제 키는 여기에 직접 입력하면 Git에 함께 업로드됩니다.
PUBLIC_DATA_SERVICE_KEY=12a3bace0d28d6a6e847b3ca25720d0c97c96a6bde153244116c52311bb76cb4

# 동물병원 인허가/조회 공공데이터 API URL입니다.
PUBLIC_DATA_ANIMAL_HOSPITAL_API_URL=https://apis.data.go.kr/1741000/animal_hospitals/info

# 동물병원 검색에 공공데이터 API를 사용할지 여부입니다.
# 키를 넣기 전까지는 false로 두면 로컬 샘플 데이터 fallback을 사용합니다.
USE_PUBLIC_DATA_API=true

# 한국과학기술정보연구원 동물질병 증상분류 공공데이터 API URL입니다.
# PUBLIC_DATA_SERVICE_KEY를 serviceKey 요청 파라미터로 사용합니다.
PUBLIC_DATA_SYMPTOM_API_URL=https://api.odcloud.kr/api/15050441/v1/uddi:cc7486db-c496-4497-8ade-e75a7b463406

# 증상 분류에 공공데이터 API를 사용할지 여부입니다.
USE_SYMPTOM_PUBLIC_DATA=true

# 사진 관찰 기록을 저장할 JSON 파일 경로입니다.
PHOTO_RECORDS_PATH=src/data/photoRecords.json

# 위험 음식 섭취 기록을 저장할 JSON 파일 경로입니다.
FOOD_INGESTION_RECORDS_PATH=src/data/foodIngestionRecords.json

USE_PET_FOOD_PUBLIC_DATA=true

PUBLIC_DATA_PET_FOOD_API_URL=https://api.nongsaro.go.kr/service/feedRawMaterial/feedRawMaterialList

PUBLIC_DATA_PET_FOOD_SERVICE_KEY=20260626ZTY72COL5OSSUF0BWY5G
